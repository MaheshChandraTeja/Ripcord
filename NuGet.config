<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clear inherited sources to make restores deterministic -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Optional GitHub Packages feed (disabled unless GH_PAT provided) -->
    <add key="github" value="https://nuget.pkg.github.com/OWNER/index.json" />
  </packageSources>

  <!-- Only enable GitHub source when a token is provided in CI -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="Company.*" />
      <package pattern="Ripcord.*" />
    </packageSource>
  </packageSourceMapping>

  <packageSourceCredentials>
    <github>
      <add key="Username" value="OWNER" />
      <add key="ClearTextPassword" value="%GH_PACKAGES_TOKEN%" />
    </github>
  </packageSourceCredentials>

  <config>
    <!-- Fail fast if a package is missing -->
    <add key="dependencyVersion" value="Highest" />
    <add key="signatureValidationMode" value="accept" />
  </config>
</configuration>
