<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand colors -->
    <Color x:Key="RipcordPrimaryColor">#FF0078D4</Color>
    <Color x:Key="RipcordPrimaryColorDark">#FF004C87</Color>
    <Color x:Key="RipcordAccentColor">#FF00C853</Color>

    <SolidColorBrush x:Key="RipcordPrimaryBrush" Color="{StaticResource RipcordPrimaryColor}" />
    <SolidColorBrush x:Key="RipcordPrimaryDarkBrush" Color="{StaticResource RipcordPrimaryColorDark}" />
    <SolidColorBrush x:Key="RipcordAccentBrush" Color="{StaticResource RipcordAccentColor}" />

    <!-- Buttons -->
    <Style TargetType="Button">
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <!-- TextBox -->
    <Style TargetType="TextBox">
        <Setter Property="MinWidth" Value="200"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- ComboBox -->
    <Style TargetType="ComboBox">
        <Setter Property="MinWidth" Value="180"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- ProgressBar -->
    <Style TargetType="ProgressBar">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- Page -->
    <Style TargetType="Page">
        <Setter Property="Background" Value="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
        <Setter Property="Padding" Value="12" />
    </Style>
</ResourceDictionary>
