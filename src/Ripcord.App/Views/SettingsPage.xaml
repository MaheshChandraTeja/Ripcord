<Page
    x:Class="Ripcord.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Ripcord.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Spacing="16">
            <GroupBox Header="Elevation & Broker">
                <StackPanel Spacing="8">
                    <ToggleSwitch x:Name="UseBrokerToggle" Header="Prefer elevated broker when available" />
                    <ToggleSwitch x:Name="AutoStartBrokerToggle" Header="Start broker automatically if not running" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Ping Broker" Click="OnPingBroker"/>
                        <TextBlock x:Name="BrokerStatusText" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Receipts">
                <StackPanel Spacing="8">
                    <TextBox x:Name="ReceiptsFolderBox" Header="Receipts Folder" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Open…" Click="OnOpenReceipts"/>
                        <Button Content="Browse…" Click="OnBrowseReceipts"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Save" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Page>
