<Page
    x:Class="Ripcord.App.Views.ShadowPurgePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Ripcord.App.ViewModels"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:ShadowPurgeViewModel />
    </Page.DataContext>

    <Grid RowSpacing="8" Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox Width="220" Header="Volume (e.g., C:\)" Text="{Binding VolumeRoot, Mode=TwoWay}" />
            <CheckBox Content="Include client-accessible (Previous Versions)" IsChecked="{Binding IncludeClientAccessible, Mode=TwoWay}" />
            <NumberBox Width="150" Header="Older than (days)" Value="{Binding OlderThanDays, Mode=TwoWay}" Minimum="0" SmallChange="1"/>
            <ToggleSwitch Header="Dry Run" IsOn="{Binding DryRun, Mode=TwoWay}" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Content="Purge" Command="{Binding PurgeCommand}" IsEnabled="{Binding CanPurge}" />
        </StackPanel>

        <!-- List -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Summary}" />

            <ListView Grid.Row="1" ItemsSource="{Binding Snapshots}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ShadowPurgeViewModel+ShadowItem">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Bind Id}" />
                                <TextBlock Text="{x:Bind DeviceObject}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock>
                                    <Run Text="Volume: "/><Run Text="{x:Bind VolumeName}"/>
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Created: "/><Run Text="{x:Bind CreatedDisplay}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                <Button Content="Delete" Command="{Binding DataContext.DeleteOneCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding Footer}" />
    </Grid>
</Page>
