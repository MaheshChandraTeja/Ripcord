<Page
    x:Class="Ripcord.App.Views.JobsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Ripcord.App.ViewModels">

    <Page.DataContext>
        <vm:JobQueueViewModel />
    </Page.DataContext>

    <Grid Padding="12" RowSpacing="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="PathBox" Width="520" PlaceholderText="File or folder path…" />
            <Button Content="Add File" Click="OnAddFile"/>
            <Button Content="Add Folder" Click="OnAddFolder"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Items}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:JobItemViewModel"
                            xmlns:controls="using:Ripcord.App.Controls">
                    <controls:ProgressListItem
                        FilePath="{x:Bind Path}"
                        Status="{x:Bind Status}"
                        Percent="{x:Bind Percent}"
                        BytesProcessed="{x:Bind BytesProcessed}"
                        BytesTotal="{x:Bind BytesTotal}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
